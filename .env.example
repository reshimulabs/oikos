# ╔══════════════════════════════════════════════════════════════╗
# ║  Oikos Agent Configuration                                   ║
# ║                                                               ║
# ║  Quick start:                                                 ║
# ║    Demo (all mocks):  npm run demo                            ║
# ║    Live swarm:        npm run live -- --name "MyAgent"        ║
# ║    Live + custom port: npm run live -- --name "X" --port 3421 ║
# ║                                                               ║
# ║  The start scripts set most env vars for you.                 ║
# ║  This .env is for secrets and overrides only.                 ║
# ╚══════════════════════════════════════════════════════════════╝

# === OIKOS MODE ===
# Controls defaults for all mock flags.
#   mock    → all mocks on (zero deps, good for dev)
#   testnet → real services (swarm, wallet on testnet)
#   mainnet → production (future)
# Individual MOCK_* flags override the mode default.
# TIP: Use `npm run live` or `npm run demo` instead of setting this manually.
OIKOS_MODE="mock"

# === WALLET ISOLATE ===
# Seed phrase — 24 words, generated via: npm run generate-seed
# NEVER commit the real .env file. This is a placeholder only.
WALLET_SEED="abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon art"

# Policy file path (relative to project root)
POLICY_FILE="policies.json"

# Audit log path
AUDIT_LOG_PATH="audit.jsonl"

# Wallet runtime: 'node' or 'bare'
WALLET_RUNTIME="node"

# === MOCK OVERRIDES ===
# These override the OIKOS_MODE default. Uncomment to force on/off.
# MOCK_WALLET=true       # Mock wallet (no real blockchain)
# MOCK_SWARM=false       # Real Hyperswarm P2P (set false for live agents!)
# MOCK_EVENTS=true       # Mock event stream

# === CHAIN CONFIGURATION ===
# BTC testnet
BTC_NETWORK="testnet"
BTC_ELECTRUM_HOST="electrum.blockstream.info"
BTC_ELECTRUM_PORT="50001"

# Ethereum Sepolia
ETH_RPC_URL="https://rpc.sepolia.org"

# === WDK INDEXER ===
# INDEXER_API_KEY="your-indexer-api-key"
# INDEXER_BASE_URL="https://wdk-api.tether.io/api/v1"

# === SWARM ===
# Enable/disable swarm P2P networking
SWARM_ENABLED="true"

# Swarm ID — all agents in the same swarm use the same ID
SWARM_ID="oikos-hackathon-v1"

# Your agent's display name on the swarm
AGENT_NAME="Oikos-Agent-1"

# Comma-separated capabilities (shown to other agents)
AGENT_CAPABILITIES="payment,swap,bridge,yield,analysis,price-feed"

# Path to persist Ed25519 keypair (auto-generated on first run)
KEYPAIR_PATH=".oikos-keypair.json"

# Bootstrap peers — comma-separated Noise pubkeys (hex) to always connect to
# SWARM_BOOTSTRAP_PEERS=""

# Relay peer for NAT traversal (default: Oikos VPS relay)
# SWARM_RELAY_PUBKEY="e7ab6adb1a18e7d22649691dc65f5789f6fdd25422b0770ab068ee9bbe0a3003"

# === AGENT BRAIN ===
# Brain type: 'ollama' (local LLM), 'http' (external), 'mock' (deterministic)
# BRAIN_TYPE="ollama"

# Ollama config (when BRAIN_TYPE=ollama)
# BRAIN_CHAT_URL="http://127.0.0.1:11434"
BRAIN_MODEL="qwen3:8b"

# LLM mode (legacy): "local" (Ollama) or "cloud" (remote API)
LLM_MODE="local"

# Ollama (local mode)
OLLAMA_URL="http://localhost:11434/v1"
OLLAMA_MODEL="qwen3:8b"

# Cloud mode (only if LLM_MODE=cloud)
# LLM_API_KEY="your-api-key-here"
# LLM_BASE_URL="https://api.anthropic.com/v1"
# LLM_MODEL="claude-sonnet-4-20250514"

# === EVENT SOURCE ===
# Rumble API key (optional, only for live stream monitoring)
# RUMBLE_API_KEY="your-rumble-api-key"

# === DASHBOARD ===
DASHBOARD_PORT="3420"
# Set to 0.0.0.0 for public access (e.g., gateway node)
DASHBOARD_HOST="127.0.0.1"

# === ERC-8004 ON-CHAIN IDENTITY ===
ERC8004_ENABLED="false"

# === COMPANION APP (P2P Human-Agent Channel) ===
COMPANION_ENABLED="false"
# COMPANION_OWNER_PUBKEY="your-owner-pubkey-hex-here"
COMPANION_TOPIC_SEED="oikos-companion-default"
COMPANION_UPDATE_INTERVAL_MS="5000"

# === RGB ===
RGB_ENABLED="false"
# RGB_TRANSPORT_PORT="13100"
