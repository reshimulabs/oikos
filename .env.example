# === WALLET ISOLATE ===
# Seed phrase — 24 words, generated via: npm run generate-seed
# NEVER commit the real .env file. This is a placeholder only.
WALLET_SEED="abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon art"

# Policy file path (relative to wallet-isolate/)
POLICY_FILE="policies.json"

# Audit log path
AUDIT_LOG_PATH="audit.jsonl"

# === CHAIN CONFIGURATION ===
# BTC testnet
BTC_NETWORK="testnet"
BTC_ELECTRUM_HOST="electrum.blockstream.info"
BTC_ELECTRUM_PORT="50001"

# Ethereum Sepolia
ETH_RPC_URL="https://rpc.sepolia.org"

# === AGENT BRAIN ===
# LLM mode: "local" (Ollama) or "cloud" (remote API)
LLM_MODE="local"

# Ollama (local mode)
OLLAMA_URL="http://localhost:11434/v1"
OLLAMA_MODEL="qwen3:8b"

# Cloud mode (only if LLM_MODE=cloud)
# LLM_API_KEY="your-api-key-here"
# LLM_BASE_URL="https://api.anthropic.com/v1"
# LLM_MODEL="claude-sonnet-4-20250514"

# Mock mode — deterministic responses, no LLM needed
MOCK_LLM="false"

# === EVENT SOURCE ===
# Use mock fixture data (no API key needed)
MOCK_EVENTS="true"

# Rumble API key (optional, only for live stream monitoring)
# RUMBLE_API_KEY="your-rumble-api-key"

# === DASHBOARD ===
DASHBOARD_PORT="3420"
